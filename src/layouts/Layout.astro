---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'CompoundVR catalogs, reviews, and evaluates flat-to-VR games and mods.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href="/">CompoundVR</a>
        <nav>
          <a href="/games/">Games</a>
          <a href="/articles/">Articles</a>
          <a href="/methodology/">Methodology</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-wrap">
        <p>CompoundVR — flat-to-VR analysis, reviews, and setup intelligence.</p>
        <p>Built for autonomous publishing with Richard as managing editor.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0b1020;
    --surface: #111831;
    --surface-2: #171f3d;
    --text: #e8ecf8;
    --muted: #aab5d6;
    --accent: #6ee7ff;
    --accent-2: #8b5cf6;
    --border: rgba(255,255,255,0.1);
    --max: 1120px;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: linear-gradient(180deg, #0a0f1f 0%, #0d1328 100%); color: var(--text); font-family: Inter, ui-sans-serif, system-ui, sans-serif; }
  body { min-height: 100vh; }
  a { color: var(--accent); text-decoration: none; }
  a:hover { opacity: 0.9; }
  .container { width: min(var(--max), calc(100% - 2rem)); margin: 0 auto; }
  .site-header { position: sticky; top: 0; z-index: 20; backdrop-filter: blur(14px); background: rgba(10,15,31,0.82); border-bottom: 1px solid var(--border); }
  .nav-wrap { display: flex; align-items: center; justify-content: space-between; padding: 1rem 0; gap: 1rem; }
  .brand { font-size: 1.2rem; font-weight: 800; letter-spacing: 0.02em; color: white; }
  nav { display: flex; gap: 1rem; flex-wrap: wrap; }
  nav a { color: var(--muted); font-weight: 600; }
  main { padding: 2rem 0 4rem; }
  .site-footer { border-top: 1px solid var(--border); margin-top: 4rem; }
  .footer-wrap { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; color: var(--muted); padding: 1.5rem 0 2rem; font-size: 0.95rem; }
  .hero { padding: 2rem 0 1rem; }
  .eyebrow { color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; font-size: 0.8rem; }
  h1, h2, h3 { line-height: 1.1; margin: 0 0 0.75rem; }
  h1 { font-size: clamp(2.4rem, 5vw, 4.5rem); max-width: 13ch; }
  h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); }
  p.lead { font-size: 1.1rem; line-height: 1.7; color: var(--muted); max-width: 72ch; }
  .grid { display: grid; gap: 1rem; }
  .grid.two { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .card { background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.04)); border: 1px solid var(--border); border-radius: 20px; padding: 1.25rem; }
  .pill { display: inline-flex; border: 1px solid var(--border); border-radius: 999px; padding: 0.35rem 0.7rem; font-size: 0.82rem; color: var(--muted); margin-right: 0.5rem; margin-bottom: 0.5rem; }
  .section { padding: 2rem 0; }
  .meta { color: var(--muted); font-size: 0.95rem; }
  .score { font-weight: 800; color: white; font-size: 1.5rem; }
  article.prose { max-width: 78ch; }
  article.prose p, article.prose li { color: var(--muted); line-height: 1.8; }
  article.prose h2, article.prose h3 { margin-top: 2rem; }
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 0.75rem; }
  .stat { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 0.9rem; }
  .stat-label { color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-value { margin-top: 0.35rem; font-weight: 700; }
</style>
