---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'CompoundVR catalogs, reviews, and evaluates flat-to-VR games and mods.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href="/" aria-label="CompoundVR home">
          <img src="/compoundvr-logo-v5.webp" alt="CompoundVR home" class="brand-logo" />
        </a>
        <nav>
          <a href="/games/">Games</a>
          <a href="/articles/">Articles</a>
          <a href="/methodology/">Methodology</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-wrap">
        <div class="footer-section">
          <h4>CompoundVR</h4>
          <p>Flat-to-VR analysis, reviews, and setup intelligence.</p>
        </div>
        <div class="footer-section">
          <h4>Navigate</h4>
          <nav class="footer-nav">
            <a href="/games/">Games</a>
            <a href="/articles/">Articles</a>
            <a href="/methodology/">Methodology</a>
          </nav>
        </div>
        <div class="footer-section">
          <p class="footer-meta">Built for autonomous publishing with Richard as managing editor.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Design System: Technical Authority v2 */
  /* Source: /design/compoundvr-brand-direction-v2.md */
  /* Light Body, Dark Header */

  :root {
    /* ========================================
       COLOR SYSTEM v2 — Light Body, Dark Header
       ======================================== */
    
    /* Background Colors */
    --bg-header: #0b1020;           /* Dark header — matches logo */
    --bg-body: #fafafa;             /* Warm off-white main background */
    --bg-secondary: #f5f5f5;        /* Section alternates */
    --bg-tertiary: #eeeeee;         /* Subtle section backgrounds */
    
    /* Surface Colors (Cards, Modals) */
    --surface-primary: #ffffff;     /* Standard cards */
    --surface-secondary: #f8f9fa;   /* Hover states */
    --surface-tertiary: #f0f0f0;   /* Active states */
    --surface-elevated: #ffffff;    /* Modals, dropdowns */
    
    /* Text Colors — Light Context */
    --text-primary: #1a1a2e;        /* Headlines — near-black */
    --text-secondary: #4a4a5a;      /* Body copy */
    --text-tertiary: #6b6b7b;       /* Metadata, captions */
    --text-muted: #9a9aaa;          /* Disabled, hints */
    
    /* Text Colors — Dark Context (Header) */
    --text-inverted: #f0f4ff;       /* Text on dark backgrounds */
    --text-inverted-secondary: rgba(240, 244, 255, 0.7);
    --text-inverted-tertiary: rgba(240, 244, 255, 0.5);
    
    /* Accent Colors */
    --accent-cyan: #0ee7ff;         /* Primary accent — slightly darker for light */
    --accent-cyan-glow: rgba(14, 231, 255, 0.2);
    --accent-cyan-subtle: rgba(14, 231, 255, 0.1);
    --accent-purple: #8b5cf6;
    --accent-purple-subtle: rgba(139, 92, 246, 0.1);
    --accent-success: #22c55e;
    --accent-warning: #f59e0b;
    --accent-error: #ef4444;
    
    /* Border Colors — Light Context */
    --border-subtle: rgba(0, 0, 0, 0.06);
    --border-default: rgba(0, 0, 0, 0.1);
    --border-strong: rgba(0, 0, 0, 0.15);
    --border-accent: rgba(14, 231, 255, 0.5);
    
    /* Border Colors — Dark Context (Header) */
    --border-inverted: rgba(255, 255, 255, 0.06);
    --border-inverted-default: rgba(255, 255, 255, 0.1);
    
    /* Typography */
    --font-sans: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "JetBrains Mono", "Fira Code", "SF Mono", monospace;
    
    /* Spacing */
    --max: 1280px;
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.25rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-10: 2.5rem;
    --space-12: 3rem;
    --space-16: 4rem;
    
    /* Transitions */
    --transition-fast: 0.15s ease;
    --transition-base: 0.2s ease;
    
    /* Shadows — Light Context */
    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
    --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.04);
    --shadow-lg: 0 4px 12px rgba(0, 0, 0, 0.08);
    --shadow-xl: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  * { box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    background: var(--bg-body);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
  }

  /* Selection Color */
  ::selection {
    background: var(--accent-cyan-subtle);
    color: var(--text-primary);
  }

  /* Links — Light Context */
  a {
    color: var(--accent-cyan);
    text-decoration: none;
    transition: var(--transition-fast);
  }

  a:hover {
    color: #0bc8d8; /* Slightly darker cyan */
    text-decoration: underline;
  }

  a:focus-visible {
    outline: 2px solid var(--accent-cyan);
    outline-offset: 2px;
  }

  /* Container */
  .container {
    width: min(var(--max), calc(100% - 2rem));
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1rem;
    }
  }

  /* ========================================
     HEADER — Dark (Preserved from Logo)
     ======================================== */
  .site-header {
    background: var(--bg-header);
    color: var(--text-inverted);
    border-bottom: 1px solid var(--border-inverted);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    height: 72px;
  }

  .nav-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .brand-logo {
    height: 48px;
    width: auto;
    display: block;
    border-radius: 8px;
  }

  /* Header Navigation — Dark Context */
  .site-header nav {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .site-header nav a {
    color: var(--text-inverted-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    transition: var(--transition-fast);
    text-decoration: none;
  }

  .site-header nav a:hover {
    color: var(--text-inverted);
    background: rgba(255, 255, 255, 0.05);
    text-decoration: none;
  }

  .site-header nav a:focus-visible {
    outline: 2px solid var(--accent-cyan);
    outline-offset: 2px;
  }

  /* Main content */
  main {
    padding: 2rem 0 4rem;
  }

  /* ========================================
     FOOTER — Light Context
     ======================================== */
  .site-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-subtle);
    margin-top: 4rem;
    padding: 2.5rem 0 3rem;
  }

  .footer-wrap {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .footer-section h4 {
    color: var(--text-primary);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }

  .footer-section p {
    color: var(--text-tertiary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav a {
    color: var(--text-tertiary);
    font-size: 0.9rem;
  }

  .footer-nav a:hover {
    color: var(--text-secondary);
  }

  .footer-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* ========================================
     TYPOGRAPHY — Light Context
     ======================================== */
  h1, h2, h3, h4, h5, h6 {
    color: var(--text-primary);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  h1 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  h2 {
    font-size: clamp(1.375rem, 2.5vw, 2rem);
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  h3 {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
  }

  h4 {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
  }

  p {
    color: var(--text-secondary);
    max-width: 70ch;
  }

  /* Eyebrow text */
  .eyebrow {
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    font-size: 0.75rem;
    margin-bottom: 0.75rem;
  }

  /* Lead paragraph */
  p.lead {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 70ch;
  }

  /* ========================================
     LAYOUT
     ======================================== */
  .section {
    padding: 3rem 0;
  }

  .section--alt {
    background: var(--bg-secondary);
  }

  .hero {
    padding: 4rem 0 2rem;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    max-width: 20ch;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 60ch;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  /* Grid */
  .grid {
    display: grid;
    gap: 1.5rem;
  }

  .grid.two {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  /* ========================================
     CARDS — Light Context
     ======================================== */
  .card {
    background: var(--surface-primary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all var(--transition-base);
    box-shadow: var(--shadow-sm);
  }

  .card:hover {
    border-color: var(--border-default);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .card:active {
    background: var(--surface-secondary);
    transform: translateY(0);
  }

  .card:focus-within {
    outline: 2px solid var(--accent-cyan);
    outline-offset: 2px;
  }

  .card-title {
    color: var(--text-primary);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .card-description {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .card-meta {
    color: var(--text-tertiary);
    font-size: 0.875rem;
  }

  /* ========================================
     PILLS / TAGS — Light Context
     ======================================== */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.35rem 0.75rem;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .pill:hover {
    border-color: var(--border-default);
    color: var(--text-secondary);
  }

  /* Pill Variants */
  .pill--success {
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.2);
    color: var(--accent-success);
  }

  .pill--warning {
    background: rgba(245, 158, 11, 0.1);
    border-color: rgba(245, 158, 11, 0.2);
    color: var(--accent-warning);
  }

  .pill--error {
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.2);
    color: var(--accent-error);
  }

  .pill--accent {
    background: var(--accent-cyan-subtle);
    border-color: rgba(14, 231, 255, 0.2);
    color: #0bc8d8;
  }

  /* ========================================
     SCORE BADGES — Light Context
     ======================================== */
  .score {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--text-primary);
  }

  .score--large {
    font-size: 2rem;
    padding: 0.5rem 1rem;
    min-width: 80px;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .score--high {
    color: var(--accent-success);
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.2);
  }

  .score--mid {
    color: var(--accent-warning);
    background: rgba(245, 158, 11, 0.1);
    border-color: rgba(245, 158, 11, 0.2);
  }

  .score--low {
    color: var(--accent-error);
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.2);
  }

  /* ========================================
     TIER BADGES — Game Ranking System
     ======================================== */
  .tier {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--text-primary);
  }

  .tier--large {
    font-size: 2.5rem;
    padding: 0.5rem 1rem;
    min-width: 80px;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-shadow: 0 0 20px currentColor;
  }

  /* S-Tier: Exceptional — Game + Mod both excellent */
  .tier--s {
    color: #f0c674;
    background: rgba(240, 198, 116, 0.1);
    border-color: rgba(240, 198, 116, 0.3);
    text-shadow: 0 0 30px rgba(240, 198, 116, 0.5);
  }

  /* A-Tier: Excellent — Highly recommended */
  .tier--a {
    color: var(--accent-success);
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.3);
    text-shadow: 0 0 20px rgba(34, 197, 94, 0.4);
  }

  /* B-Tier: Good — Solid experience */
  .tier--b {
    color: var(--accent-cyan);
    background: var(--accent-cyan-subtle);
    border-color: rgba(14, 231, 255, 0.3);
    text-shadow: 0 0 20px rgba(14, 231, 255, 0.4);
  }

  /* C-Tier: Average — Mixed experience */
  .tier--c {
    color: var(--accent-warning);
    background: rgba(245, 158, 11, 0.1);
    border-color: rgba(245, 158, 11, 0.3);
  }

  /* D-Tier: Below Average — Significant caveats */
  .tier--d {
    color: #f97316;
    background: rgba(249, 115, 22, 0.1);
    border-color: rgba(249, 115, 22, 0.3);
  }

  /* F-Tier: Not Recommended */
  .tier--f {
    color: var(--accent-error);
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.3);
  }

  /* ========================================
     STATS — Light Context
     ======================================== */
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
  }

  .stat {
    background: var(--surface-primary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 1rem;
  }

  .stat-label {
    color: var(--text-tertiary);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .stat-value {
    margin-top: 0.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .stat-score {
    background: var(--surface-secondary);
    border-color: var(--border-default);
  }

  /* ========================================
     BUTTONS — Light Context
     ======================================== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .btn:focus-visible {
    outline: 2px solid var(--accent-cyan);
    outline-offset: 2px;
  }

  /* Primary Button */
  .btn--primary {
    background: var(--accent-cyan);
    color: #0b1020;
  }

  .btn--primary:hover {
    background: #5dd5e8;
    box-shadow: 0 4px 12px rgba(14, 231, 255, 0.3);
    text-decoration: none;
  }

  .btn--primary:active {
    background: #4cc5d8;
    transform: scale(0.98);
  }

  /* Secondary Button */
  .btn--secondary {
    background: transparent;
    border: 1px solid var(--border-default);
    color: var(--text-primary);
  }

  .btn--secondary:hover {
    background: rgba(0, 0, 0, 0.04);
    border-color: var(--border-strong);
    text-decoration: none;
  }

  .btn--secondary:active {
    background: rgba(0, 0, 0, 0.08);
  }

  /* Ghost Button */
  .btn--ghost {
    background: transparent;
    color: var(--accent-cyan);
    padding: 0.5rem 1rem;
  }

  .btn--ghost:hover {
    background: var(--accent-cyan-subtle);
    text-decoration: none;
  }

  /* ========================================
     ARTICLE PROSE
     ======================================== */
  article.prose {
    max-width: 70ch;
    overflow-x: auto;
  }

  article.prose p,
  article.prose li {
    color: var(--text-secondary);
    line-height: 1.8;
  }

  article.prose h2,
  article.prose h3 {
    margin-top: 2.5rem;
    color: var(--text-primary);
  }

  /* Markdown Tables */
  article.prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
    display: block;
    overflow-x: auto;
  }

  article.prose thead {
    background: var(--bg-secondary);
  }

  article.prose th {
    text-align: left;
    padding: 0.75rem 1rem;
    font-weight: 600;
    color: var(--text-primary);
    border-bottom: 2px solid var(--border-default);
  }

  article.prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-secondary);
  }

  article.prose tr:hover td {
    background: var(--bg-secondary);
  }

  /* Lists */
  article.prose ul,
  article.prose ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  article.prose li {
    margin: 0.5rem 0;
  }

  /* Blockquotes */
  article.prose blockquote {
    border-left: 3px solid var(--accent-cyan);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--text-tertiary);
    font-style: italic;
  }

  /* Code */
  article.prose code {
    background: var(--bg-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  article.prose pre {
    background: var(--bg-tertiary);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }

  article.prose pre code {
    background: none;
    padding: 0;
  }

  /* ========================================
     SOURCE LOG — Editorial Footnotes
     ======================================== */
  /* The last h2 in article prose ("Source Log") and everything after it
     renders as small footnotes, visually separated from the article body */
  article.prose .source-log,
  article.prose details.source-log {
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--text-muted);
    border-top: 1px solid var(--border-subtle);
    padding-top: 1rem;
    margin-top: 3rem;
  }

  article.prose details.source-log summary {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-tertiary);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  article.prose details.source-log ul,
  article.prose details.source-log ol {
    font-size: 0.75rem;
    margin: 0.5rem 0;
    padding-left: 1rem;
  }

  article.prose details.source-log li {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0.25rem 0;
  }

  /* ========================================
     META
     ======================================== */
  .meta {
    color: var(--text-tertiary);
    font-size: 0.875rem;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 720px) {
    .site-header {
      height: auto;
      min-height: 64px;
    }

    .nav-wrap {
      display: grid;
      grid-template-columns: 1fr;
      justify-items: center;
