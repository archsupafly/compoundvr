---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map((game) => ({ params: { slug: game.id }, props: { game } }));
}

const { game } = Astro.props;
const { Content } = await render(game);

// Determine tier class
const tier = game.data.tier || 'B';

// Route type YAML → gamer-friendly display labels
const routeTypeLabels: Record<string, string> = {
  'Official Hybrid': 'Official VR Mode',
  'Official Standalone VR Version': 'Standalone VR',
  'Full VR Mod': 'Full VR Mod',
  'Framework-Based': 'VR Framework',
  'Injection Driver': '3D Injection',
  'Multi-Route Coverage': 'Multiple VR Options',
  'Emulator': 'VR Emulator',
};
let tierClass = 'tier tier--large';
if (tier === 'S') tierClass = 'tier tier--large tier--s';
else if (tier === 'A') tierClass = 'tier tier--large tier--a';
else if (tier === 'B') tierClass = 'tier tier--large tier--b';
else if (tier === 'C') tierClass = 'tier tier--large tier--c';
else if (tier === 'D') tierClass = 'tier tier--large tier--d';
else tierClass = 'tier tier--large tier--f';

// Short date: Sep 26, 1986
function formatShortDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

// Numeric date: 01/08/2018
function formatNumericDate(date: Date): string {
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  const y = date.getFullYear();
  return `${m}/${d}/${y}`;
}
---

<Layout title={`${game.data.title} — CompoundVR`} description={game.data.description}>
  {game.data.heroImage && (
    <div class="hero-image-container">
      <img src={game.data.heroImage} alt={game.data.title} class="hero-image" />
      <div class="hero-overlay"></div>
    </div>
  )}
  <section class="container section game-page">
    <div class="eyebrow">Last verified {game.data.lastVerified.toISOString().slice(0, 10)}</div>
    <h1>{game.data.title}</h1>
    <p class="lead">{game.data.description}</p>

    <div class="stats" style="margin-top:1.5rem;">
      <div class="stat">
        <div class="stat-label">Release</div>
        <div class="stat-value">
          {game.data.flatReleaseDate && formatShortDate(game.data.flatReleaseDate)}
          {game.data.flatReleaseDate && game.data.vrReleaseDate && <><br /><span class="stat-note">VR mod {formatNumericDate(game.data.vrReleaseDate)}</span></>}
          {!game.data.flatReleaseDate && game.data.vrReleaseDate && formatShortDate(game.data.vrReleaseDate)}
        </div>
      </div>
      <div class="stat">
        <div class="stat-label">VR Option</div>
        <div class="stat-value">{routeTypeLabels[game.data.routeType] || game.data.routeType}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Platforms</div>
        <div class="stat-value">{game.data.platforms.join(', ')}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Setup</div>
        <div class="stat-value">{game.data.setupBurden}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Input</div>
        <div class="stat-value">{game.data.inputStyle}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Comfort</div>
        <div class="stat-value">{game.data.comfort}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Performance</div>
        <div class="stat-value">{game.data.performance}</div>
      </div>
      <div class="stat stat-tier">
        <div class="stat-label">Tier</div>
        <div class={tierClass}>{tier}</div>
      </div>
    </div>

    <article class="prose article-content" style="margin-top:2rem;">
      <Content />
    </article>

    <div class="card verdict-card" style="margin-top:2rem;">
      <div class="verdict-header">
        <div class="verdict-header-left">
          <h3>Verdict</h3>
          <span class="recommendation-label">{game.data.recommendation}</span>
        </div>
        <div class={tierClass}>{tier}</div>
      </div>
      <p class="lead" style="font-size:1rem;max-width:none;">{game.data.verdict}</p>
    </div>

    <div class="tags-container tags-bottom" style="margin-top:1.5rem;">
      {[...game.data.genres, ...game.data.technicalTags, ...game.data.experienceTags].map((tag: string) => (
        <span class="pill">{tag}</span>
      ))}
    </div>

    {game.data.sources && (
      <details class="source-log" style="margin-top:1rem;">
        <summary>Sources</summary>
        <div class="source-log-content" style="margin-top:0.75rem;">{game.data.sources}</div>
      </details>
    )}
  </section>
</Layout>

<style>

  .hero-image-container {
    width: 100%;
    height: 400px;
    position: relative;
    overflow: hidden;
    background: var(--bg-secondary);
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100px;
    background: linear-gradient(transparent, var(--bg-body));
  }

  .game-page {
    margin-top: -2rem;
    position: relative;
    z-index: 1;
    max-width: var(--max);
    margin-left: auto;
    margin-right: auto;
  }

  .stat-tier {
    background: var(--surface-secondary);
    border-color: var(--border-default);
  }

  .verdict-card {
    border: 1px solid var(--border-default);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    background: var(--surface-secondary);
  }

  .verdict-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .verdict-header h3 {
    margin: 0;
    color: var(--text-primary);
  }

  .verdict-header-left {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .recommendation-label {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    font-weight: 400;
  }

  .tags-bottom {
    justify-content: center;
  }

  .stat-note {
    color: var(--text-tertiary);
    font-size: 0.75rem;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .source-log {
    border: 1px solid var(--border-default);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    background: var(--surface-secondary);
  }

  .source-log summary {
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--text-tertiary);
    font-weight: 500;
    list-style: none;
  }

  .source-log summary::-webkit-details-marker {
    display: none;
  }

  .source-log summary::before {
    content: '▸ ';
  }

  .source-log[open] summary::before {
    content: '▾ ';
  }

  .source-log-content {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    line-height: 1.6;
  }

  @media (max-width: 720px) {
    .hero-image-container {
      height: 250px;
    }
  }
</style>
