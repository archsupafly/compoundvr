---
import Layout from '../layouts/Layout.astro';
import CardGrid from '../components/CardGrid.astro';
import ArticleGrid from '../components/ArticleGrid.astro';
import FeaturedHero from '../components/FeaturedHero.astro';
import { getCollection } from 'astro:content';

// Sort games by last verified date (newest first) for freshness
const allGames = (await getCollection('games')).sort((a, b) => {
  const dateA = a.data.lastVerified?.valueOf() || 0;
  const dateB = b.data.lastVerified?.valueOf() || 0;
  return dateB - dateA;
});

// Games for the 2-column grid (up to 12)
const displayGames = allGames.slice(0, 12);

// Articles for the sidebar column (up to 4, exclude featured ones already in carousel)
const featuredSlugs = ['flatout-4-vr', 'microsoft-flight-simulator', 'dolphin-vr', 'triangle-strategy', 'ppsspp-vr'];
const allArticles = (await getCollection('articles')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sidebarArticles = allArticles
  .filter(a => !featuredSlugs.includes(a.id))
  .slice(0, 4);

// Featured items: games + articles in editorial order
const gamesMap = Object.fromEntries(allGames.map(g => [g.id, g]));
const articlesMap = Object.fromEntries(allArticles.map(a => [a.id, a]));

const featuredItems = featuredSlugs
  .map(slug => {
    const game = gamesMap[slug];
    if (game) {
      return {
        href: `/games/${game.id}/`,
        title: game.data.title,
        description: game.data.verdict,
        heroImage: game.data.heroImage,
        category: 'game',
        date: game.data.lastVerified || game.data.flatReleaseDate || new Date(),
      };
    }
    const article = articlesMap[slug];
    if (article) {
      return {
        href: `/articles/${article.id}/`,
        title: article.data.title,
        description: article.data.description,
        heroImage: article.data.heroImage,
        category: article.data.category,
        date: article.data.pubDate,
      };
    }
    return null;
  })
  .filter(Boolean);
---

<Layout title="CompoundVR — Flat-to-VR intelligence" description="CompoundVR catalogs, reviews, and evaluates flat-to-VR games and mods.">
  <section class="hero homepage-hero container">
    <div class="eyebrow">Authority site for flat-to-VR players</div>
    <h1>Your guide to the best mods, hybrid, and native VR games</h1>
    <p class="lead">
      CompoundVR is a decision database with editorial judgment layered on top — canonical game pages,
      setup reality checks, and trustworthy verdicts on whether playing in VR is actually worth your time.
    </p>
  </section>

  {featuredItems.length > 0 && (
    <section class="section homepage-featured container">
      <FeaturedHero items={featuredItems} />
    </section>
  )}

  <section class="section container">
    <h2>Games</h2>
    <div class="home-grid">
      <div class="home-grid__games">
        <CardGrid items={displayGames.map((game) => ({
          href: `/games/${game.id}/`,
          title: game.data.title,
          description: game.data.verdict,
          heroImage: game.data.heroImage,
          tier: game.data.tier,
          routeType: game.data.routeType,
          platforms: game.data.platforms,
          recommendation: game.data.recommendation,
          setupBurden: game.data.setupBurden,
        }))} columns={2} />
      </div>
      <div class="home-grid__articles">
        <h3>Articles</h3>
        <ArticleGrid items={sidebarArticles.map((article) => ({
          href: `/articles/${article.id}/`,
          title: article.data.title,
          description: article.data.description,
          heroImage: article.data.heroImage,
          meta: `${article.data.category} · ${article.data.pubDate.toISOString().slice(0, 10)}`,
        }))} columns={1} />
      </div>
    </div>
  </section>

  <section class="section container">
    <h2>Editorial system</h2>
    <div class="grid two">
      <div class="card">
        <h3>Canonical game pages first</h3>
        <p class="lead" style="font-size:1rem;max-width:none;">
          The primary unit is the evergreen game page. Articles, guides, and comparisons support that structure instead of replacing it.
        </p>
      </div>
      <div class="card">
        <h3>Autonomous publishing ready</h3>
        <p class="lead" style="font-size:1rem;max-width:none;">
          Richard can publish by creating Markdown files in structured content collections. No database or heavy CMS required.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .homepage-hero {
    padding: 1.5rem 0 0.5rem;
  }
  .homepage-hero h1 {
    margin-bottom: 0.75rem;
  }
  .homepage-hero .lead {
    margin-left: auto;
    margin-right: auto;
  }
  .homepage-featured {
    padding: 0 0 2rem;
  }

  .home-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .home-grid__articles h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary, #0b1020);
    margin: 0 0 0.75rem;
  }

  @media (max-width: 900px) {
    .home-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .homepage-hero {
      padding: 1rem 0 0.25rem;
    }
  }
</style>