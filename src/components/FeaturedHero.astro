---
interface Props {
  article: {
    id: string;
    data: {
      title: string;
      description: string;
      heroImage?: string;
      category: string;
      pubDate: Date;
    };
  };
}

const { article } = Astro.props;

const categoryLabels: Record<string, string> = {
  news: 'News',
  guide: 'Guide',
  comparison: 'Comparison',
  opinion: 'Opinion',
};

const categoryClass: Record<string, string> = {
  news: 'featured-hero__pill--news',
  guide: 'featured-hero__pill--guide',
  comparison: 'featured-hero__pill--comparison',
  opinion: 'featured-hero__pill--opinion',
};
---

<a class="featured-hero" href={`/articles/${article.id}/`}>
  <div class="featured-hero__image-container">
    {article.data.heroImage ? (
      <img
        src={article.data.heroImage}
        alt={article.data.title}
        class="featured-hero__image"
      />
    ) : (
      <div class="featured-hero__image--placeholder"></div>
    )}
    <div class="featured-hero__overlay"></div>
  </div>

  <div class="featured-hero__content">
    <span class={`featured-hero__pill ${categoryClass[article.data.category] || ''}`}>
      {categoryLabels[article.data.category] || article.data.category}
    </span>
    <h2 class="featured-hero__title">{article.data.title}</h2>
    <p class="featured-hero__description">{article.data.description}</p>
    <span class="featured-hero__date">
      {article.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </span>
  </div>
</a>

<style>
  .featured-hero {
    display: block;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    margin-bottom: 1.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .featured-hero:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.35);
  }

  .featured-hero__image-container {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-tertiary, #0b1020);
  }

  .featured-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .featured-hero:hover .featured-hero__image {
    transform: scale(1.02);
  }

  .featured-hero__image--placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--bg-secondary, #1a2342), var(--bg-tertiary, #0b1020));
  }

  .featured-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(11, 16, 32, 0.92) 0%,
      rgba(11, 16, 32, 0.6) 40%,
      rgba(11, 16, 32, 0.15) 70%,
      transparent 100%
    );
    pointer-events: none;
  }

  .featured-hero__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .featured-hero__pill {
    display: inline-block;
    width: fit-content;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background: rgba(110, 231, 255, 0.2);
    color: var(--accent-cyan, #6ee7ff);
    border: 1px solid rgba(110, 231, 255, 0.3);
  }

  .featured-hero__pill--news {
    background: rgba(110, 231, 255, 0.2);
    color: var(--accent-cyan, #6ee7ff);
    border-color: rgba(110, 231, 255, 0.3);
  }

  .featured-hero__pill--guide {
    background: rgba(34, 197, 94, 0.2);
    color: #4ade80;
    border-color: rgba(34, 197, 94, 0.3);
  }

  .featured-hero__pill--comparison {
    background: rgba(168, 85, 247, 0.2);
    color: #c084fc;
    border-color: rgba(168, 85, 247, 0.3);
  }

  .featured-hero__pill--opinion {
    background: rgba(245, 158, 11, 0.2);
    color: #fbbf24;
    border-color: rgba(245, 158, 11, 0.3);
  }

  .featured-hero__title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #f0f4ff;
    line-height: 1.25;
    margin: 0;
  }

  .featured-hero:hover .featured-hero__title {
    color: var(--accent-cyan, #6ee7ff);
  }

  .featured-hero__description {
    font-size: 1rem;
    color: #c5cce6;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-hero__date {
    font-size: 0.75rem;
    color: #8b92b8;
    margin-top: 0.25rem;
  }

  @media (max-width: 1024px) {
    .featured-hero__title {
      font-size: 1.5rem;
    }

    .featured-hero__content {
      padding: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .featured-hero__title {
      font-size: 1.25rem;
    }

    .featured-hero__description {
      -webkit-line-clamp: 1;
    }

    .featured-hero__content {
      padding: 1.25rem;
      gap: 0.35rem;
    }
  }
</style>