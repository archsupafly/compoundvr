---
interface ArticleCard {
  href: string;
  title: string;
  description: string;
  heroImage?: string;
  meta?: string;
}

const { items, columns = 3, showImages = true } = Astro.props as { 
  items: ArticleCard[]; 
  columns?: 2 | 3 | 4;
  showImages?: boolean;
};
---

<div class={`article-grid article-grid--${columns}`}>
  {items.map((article) => (
    <a class="article-card" href={article.href}>
      {showImages && (
        <div class="article-card__image-container">
          {article.heroImage ? (
            <img 
              src={article.heroImage} 
              alt={article.title}
              class="article-card__image"
              loading="lazy"
            />
          ) : (
            <div class="article-card__image--placeholder"></div>
          )}
        </div>
      )}
      
      <div class="article-card__body">
        <h3 class="article-card__title">{article.title}</h3>
        <p class="article-card__description">{article.description}</p>
        {article.meta && <span class="article-card__meta">{article.meta}</span>}
      </div>
    </a>
  ))}
</div>

<style>
  .article-grid {
    display: grid;
    gap: 1.5rem;
  }
  
  .article-grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .article-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .article-grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  
  @media (max-width: 1024px) {
    .article-grid--3,
    .article-grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 640px) {
    .article-grid--2,
    .article-grid--3,
    .article-grid--4 {
      grid-template-columns: 1fr;
    }
  }
  
  .article-card {
    background: var(--surface-primary, #151d38);
    border: 1px solid var(--border-subtle, rgba(255, 255, 255, 0.08));
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  
  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
    border-color: var(--accent-cyan, rgba(110, 231, 255, 0.3));
  }
  
  .article-card__image-container {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-tertiary, #0b1020);
  }
  
  .article-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  .article-card:hover .article-card__image {
    transform: scale(1.02);
  }
  
  .article-card__image--placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--bg-secondary, #1a2342), var(--bg-tertiary, #0b1020));
  }
  
  .article-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  
  .article-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary, #f0f4ff);
    line-height: 1.3;
    margin: 0;
  }
  
  .article-card:hover .article-card__title {
    color: var(--accent-cyan, #6ee7ff);
  }
  
  .article-card__description {
    font-size: 0.9rem;
    color: var(--text-secondary, #c5cce6);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  
  .article-card__meta {
    font-size: 0.75rem;
    color: var(--text-tertiary, #8b92b8);
    margin-top: 0.5rem;
  }
</style>