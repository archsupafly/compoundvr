---
interface Item {
  href: string;
  title: string;
  description: string;
  meta?: string;
}

const { items } = Astro.props as { items: Item[] };
---

<div class="grid two">
  {items.map((item) => (
    <a class="card" href={item.href}>
      {item.meta && <div class="meta">{item.meta}</div>}
      <h3>{item.title}</h3>
      <p class="lead" style="font-size:1rem;max-width:none;">{item.description}</p>
    </a>
  ))}
</div>
